{
  "source_language": "en",
  "target_language": "zh-Hans",
  "profile_name": "publication",
  "provider": "openai-responses",
  "base_url": "https://api.openai.com/v1",
  "api_key_env": "OPENAI_API_KEY",
  "default_model": "replace-with-a-supported-model",
